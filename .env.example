# inkforg_apexpanel Reader — Environment
# Clerk has been removed. No authentication or third-party keys are required.
# Everything (publishing, reading, coins, unlocks, comments) is local to the browser.

# Optional: Razorpay (the Buy Coins flow is a local demo and does not call real payment APIs by default)
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
